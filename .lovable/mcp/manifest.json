      "authenticated"
    ]
  },
  "mcp": {
    "server": {
      "name": "surf-riders-mcp",
      "version": "0.1.0",
      "title": "Surf Riders 2.0"
    },
    "tools": [
      {
        "name": "get_player_profile",
        "title": "Get player profile",
        "description": "Get the signed-in Surf Riders player's profile: username, avatar, current level, silver/gold coins, gems, equipped weapon, and highest score.",
        "annotations": {
          "readOnlyHint": true,
          "idempotentHint": true,
          "openWorldHint": false
        },
        "inputSchema": {
          "$schema": "http://json-schema.org/draft-07/schema#",
          "type": "object",
          "properties": {}
        },
        "outputSchema": null
      },
      {
        "name": "list_my_weapons",
        "title": "List my weapons",
        "description": "List all weapons the signed-in player owns in Surf Riders 2.0.",
        "annotations": {
          "readOnlyHint": true,
          "idempotentHint": true,
          "openWorldHint": false
        },
        "inputSchema": {
          "$schema": "http://json-schema.org/draft-07/schema#",
          "type": "object",
          "properties": {}
        },
        "outputSchema": null
      },
      {
        "name": "get_leaderboard",
        "title": "Get leaderboard",
        "description": "Get the top Surf Riders 2.0 leaderboard entries ordered by score. Optionally filter by world.",
        "annotations": {
          "readOnlyHint": true,
          "idempotentHint": true,
          "openWorldHint": false
        },
        "inputSchema": {
          "$schema": "http://json-schema.org/draft-07/schema#",
          "type": "object",
          "properties": {
            "world": {
              "description": "Optional world key to filter by.",
              "type": "string",
              "minLength": 1,
              "maxLength": 64
            },
            "limit": {
              "description": "Max entries to return (default 10).",
              "type": "integer",
              "minimum": 1,
              "maximum": 50
            }
          }
        },
        "outputSchema": null
      }
    ]
  }
}
